# Copie ce fichier en `.env` et remplis SUPABASE_SERVICE_ROLE_KEY.
# (le .env ne doit jamais être commité — il contient la clé service_role)

SUPABASE_URL=https://drdlcohzfjdogyquglcs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=colle-ici-la-cle-service_role

# IP de l'écran SmallTV sur le LAN
SCREEN_IP=192.168.0.57

# Fréquence de vérification des nouveaux messages (secondes)
POLL_INTERVAL=4

# Polices (valeurs par défaut Ubuntu — installe-les : voir README)
TEXT_FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
EMOJI_FONT=/usr/share/fonts/truetype/noto/NotoColorEmoji.ttf
